<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OLD MAFIA - არქივი</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { --dark-red: #4a0000; --bright-red: #ff0000; }
        * { box-sizing: border-box; }
        
        body { 
            background: #030000; 
            color: white; 
            font-family: sans-serif; 
            margin: 0; 
            display: flex; 
            height: 100vh; 
            overflow: hidden; 
        }

        /* მარცხენა მენიუ */
        .sidebar-left { 
            width: 200px; 
            background: #050000; 
            border-right: 1px solid var(--dark-red); 
            display: flex; 
            flex-direction: column; 
            flex-shrink: 0;
        }
        .sidebar-header { padding: 15px; text-align: center; border-bottom: 1px solid var(--dark-red); color: var(--bright-red); font-weight: bold; font-size: 14px; letter-spacing: 1px; }
        .menu-item { padding: 12px 15px; color: #888; text-decoration: none; display: block; border-bottom: 1px solid #111; font-size: 13px; transition: 0.2s; }
        .menu-item:hover { background: #110000; color: white; }

        /* მთავარი კონტენტი */
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        
        .topbar { 
            height: 55px; 
            background: black; 
            border-bottom: 1px solid var(--dark-red); 
            display: flex; 
            align-items: center; 
            padding: 0 15px;
            gap: 15px;
        }

        /* ძებნის ინპუტი */
        .search-box {
            flex: 1;
            background: #111;
            border: 1px solid #333;
            border-radius: 20px;
            padding: 6px 15px;
            color: white;
            outline: none;
            font-size: 13px;
            transition: 0.3s;
        }
        .search-box:focus { border-color: var(--bright-red); background: #1a0000; }

        .inbox-link { text-decoration: none; font-size: 18px; filter: grayscale(1); }

        /* წევრების ბარათები */
        #users-container { 
            flex: 1; 
            overflow-y: auto; 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(105px, 105px)); 
            gap: 10px; 
            padding: 15px; 
            justify-content: center;
        }

        .user-card { 
            background: #080000; 
            border: 1px solid #1a1a1a; 
            border-radius: 10px; 
            padding: 12px 5px; 
            text-align: center; 
            cursor: pointer; 
            transition: 0.2s;
        }
        .user-card:hover { border-color: var(--bright-red); background: #110000; }

        .u-avatar { 
            width: 55px; 
            height: 55px; 
            border-radius: 50%; 
            border: 1px solid var(--dark-red); 
            object-fit: cover; 
            margin-bottom: 5px;
        }
        .u-name { 
            color: #eee; 
            font-weight: bold; 
            font-size: 11px; 
            margin: 4px 0 2px 0;
            white-space: nowrap; 
            overflow: hidden; 
            text-overflow: ellipsis; 
        }
        .u-role { color: #555; font-size: 9px; text-transform: uppercase; }

        /* სქროლი */
        #users-container::-webkit-scrollbar { width: 4px; }
        #users-container::-webkit-scrollbar-thumb { background: var(--dark-red); }

        @media (max-width: 600px) { .sidebar-left { display: none; } }
    </style>
</head>
<body>

<div class="sidebar-left">
    <div class="sidebar-header">OLD MAFIA</div>
    <div class="menu-list">
        <a href="chat.html" class="menu-item">☕ კაფე-ბარი</a>
        <a href="chat.html?room=Mafia" class="menu-item">🔫 მაფია</a>
        <a href="profile.html" class="menu-item">👤 პროფილი</a>
    </div>
</div>

<div class="main-content">
    <div class="topbar">
        <input type="text" id="userSearch" class="search-box" placeholder="მოძებნე წევრი..." oninput="filterUsers()">
        <a href="inbox.html" class="inbox-link">📩</a>
    </div>

    <div id="users-container">იტვირთება...</div>
</div>

<script>
    const _s = supabase.createClient("https://ftfciebnywbondaiarnc.supabase.co", "sb_publishable_eQZDSu_Jy1gWmXJFF800Pw_TP2kBRLI");
    let allUsers = [];

    async function loadUsers() {
        const { data, error } = await _s
            .from('profiles')
            .select('*')
            .order('username', { ascending: true });

        if (error) {
            document.getElementById('users-container').innerHTML = "შეცდომა.";
            return;
        }

        allUsers = data || [];
        renderUsers(allUsers);
    }

    function renderUsers(usersList) {
        const container = document.getElementById('users-container');
        container.innerHTML = "";
        
        if (usersList.length === 0) {
            container.innerHTML = "<div style='grid-column:1/-1; color:#444; margin-top:20px;'>ვერავინ მოიძებნა</div>";
            return;
        }

        usersList.forEach(u => {
            container.innerHTML += `
                <div class="user-card" onclick="location.href='profile.html?user=${u.username}'">
                    <img src="${u.avatar_url || 'https://i.ibb.co/v3m6y6R/avatar.png'}" class="u-avatar">
                    <div class="u-name">${u.username}</div>
                    <div class="u-role">${u.role || 'Member'}</div>
                </div>`;
        });
    }

    function filterUsers() {
        const term = document.getElementById('userSearch').value.toLowerCase();
        const filtered = allUsers.filter(u => 
            u.username.toLowerCase().includes(term)
        );
        renderUsers(filtered);
    }

    loadUsers();
</script>

</body>
</html>
