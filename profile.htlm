<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>პროფილის მართვა - Old Mafia</title>
    <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
    <style>
        body { background: radial-gradient(circle, #1a0000 0%, #000 100%); color: white; font-family: Arial; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .card { width: 90%; max-width: 420px; background: rgba(5, 5, 5, 0.95); border: 2px solid red; border-radius: 25px; padding: 30px; box-shadow: 0 0 30px rgba(255, 0, 0, 0.4); text-align: center; position: relative; }
        
        .profile-pic { width: 110px; height: 110px; border-radius: 50%; border: 3px solid red; box-shadow: 0 0 15px red; object-fit: cover; margin-bottom: 15px; }
        .u-name { font-size: 26px; font-weight: bold; text-shadow: 0 0 10px red; display: block; color: white; }
        .u-role { color: #ff4444; font-size: 14px; margin-bottom: 20px; display: block; text-transform: uppercase; letter-spacing: 1px; }

        .admin-section { margin-top: 25px; padding: 15px; border: 1px dashed red; border-radius: 15px; background: rgba(20, 0, 0, 0.5); }
        .admin-title { font-size: 12px; color: #ff8888; margin-bottom: 15px; display: block; font-weight: bold; }

        .btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        
        button { 
            padding: 12px 5px; border-radius: 12px; border: 1px solid #400; 
            background: #111; color: white; cursor: pointer; font-size: 13px; 
            transition: 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 5px;
        }
        
        button:hover { background: #300; border-color: red; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(255,0,0,0.2); }
        
        .btn-ban { background: #400; border-color: #f00; color: #ffaaaa; }
        .btn-ban:hover { background: red; color: white; }

        .back-btn { margin-top: 25px; background: none; border: none; color: #666; cursor: pointer; text-decoration: underline; font-size: 14px; }
        .back-btn:hover { color: red; }
    </style>
</head>
<body>

    <div class="card">
        <img src="https://i.ibb.co/v3m6y6R/avatar.png" class="profile-pic">
        <span class="u-name" id="pName">...</span>
        <span class="u-role" id="pRole">იტვირთება</span>

        <div id="adminControls" class="admin-section" style="display: none;">
            <span class="admin-title">🛡️ ადმინისტრატორის პანელი</span>
            <div class="btn-grid">
                <button onclick="updateRole('დამფუძნებელი')">👑 დამფუძნებლის მინიჭება</button>
                <button onclick="updateRole('ადმინი')">⭐ ადმინის მინიჭება</button>
                <button onclick="updateRole('იუზერი')">❌ როლის ჩახსნა</button>
                <button class="btn-ban" onclick="banUser()">🚫 დაბლოკვა</button>
            </div>
        </div>

        <button class="back-btn" onclick="history.back()">🔙 უკან დაბრუნება</button>
    </div>

    <script>
        const _s = supabase.createClient("https://ftfciebnywbondaiarnc.supabase.co", "sb_publishable_eQZDSu_Jy1gWmXJFF800Pw_TP2kBRLI");

        const urlParams = new URLSearchParams(window.location.search);
        const targetUser = urlParams.get('user'); // ვის პროფილში ვართ
        const myNick = localStorage.getItem('nickname'); // ვინ ვარ მე

        async function init() {
            if (!targetUser) return;
            document.getElementById('pName').innerText = targetUser;

            // 1. წამოვიღოთ იმის მონაცემები, ვისაც ვუყურებთ
            let { data: targetProfile } = await _s.from('profiles').select('role').eq('username', targetUser).single();
            if (targetProfile) {
                document.getElementById('pRole').innerText = targetProfile.role || 'მომხმარებელი';
            }

            // 2. შევამოწმოთ ჩემი უფლებები
            let { data: myProfile } = await _s.from('profiles').select('role').eq('username', myNick).single();
            
            if (myProfile) {
                const myRole = myProfile.role;
                const targetRole = targetProfile?.role || 'იუზერი';

                // პირობა: თუ ვარ დამფუძნებელი, ან ვარ ადმინი და იმას არ აქვს დამფუძნებლის როლი
                if (myRole === 'დამფუძნებელი' || (myRole === 'ადმინი' && targetRole !== 'დამფუძნებელი')) {
                    document.getElementById('adminControls').style.display = 'block';
                }
            }
        }

        async function updateRole(newRole) {
            if (!confirm(`ნამდვილად გსურთ როლის შეცვლა: ${newRole}?`)) return;

            const { error } = await _s.from('profiles')
                .update({ role: newRole })
                .eq('username', targetUser);

            if (error) {
                alert("შეცდომა: " + error.message);
            } else {
                alert("წარმატებით განახლდა!");
                location.reload();
            }
        }

        async function banUser() {
            if (!confirm(`დავბლოკოთ მომხმარებელი ${targetUser}?`)) return;
            
            // აქ შეგვიძლია profiles ცხრილში დავამატოთ სვეტი is_banned: true
            const { error } = await _s.from('profiles').update({ role: 'დაბლოკილი' }).eq('username', targetUser);
            
            if (!error) {
                alert("მომხმარებელი დაიბლოკა!");
                location.reload();
            }
        }

        window.onload = init;
    </script>
</body>
</html>
