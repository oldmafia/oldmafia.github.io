<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>ტესტი</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.7/dist/umd/supabase.js"></script>
</head>
<body style="background: black; color: white; font-family: sans-serif; text-align: center; padding: 50px;">

    <div style="border: 2px solid red; padding: 20px; display: inline-block;">
        <h1 id="status">კავშირი მყარდება...</h1>
        <div id="details"></div>
        <hr>
        <button onclick="location.reload()" style="padding: 10px; cursor: pointer;">ხელახლა ცდა</button>
    </div>

<script>
    async function test() {
        const status = document.getElementById('status');
        const details = document.getElementById('details');

        try {
            // 1. ვამოწმებთ ბიბლიოთეკას
            if (typeof supabase === 'undefined') {
                status.innerText = "❌ შეცდომა: Supabase ვერ ჩაიტვირთა!";
                return;
            }

            const _s = supabase.createClient("https://ftfciebnywbondaiarnc.supabase.co", "sb_publishable_eQZDSu_Jy1gWmXJFF800Pw_TP2kBRLI");
            
            status.innerText = "🔍 ბაზასთან კავშირი... [OK]";

            // 2. ვცდილობთ წაკითხვას
            const myNick = localStorage.getItem('nickname') || "სტუმარი";
            let { data, error } = await _s.from('profiles').select('username').limit(1);

            if (error) {
                status.innerText = "❌ ბაზამ უარი თქვა!";
                details.innerHTML = `<p style="color:red">${error.message}</p>`;
            } else {
                status.innerText = "✅ ყველაფერი მუშაობს!";
                details.innerHTML = `<p>ბაზა დაინახა. შენი ნიკი: <b>${myNick}</b></p>
                                     <p>თუ ნიკი წერტილებია, ჩატში თავიდან უნდა შეხვიდე!</p>`;
            }

        } catch (err) {
            status.innerText = "💥 კოდი გაფუჭდა!";
            details.innerText = err.message;
        }
    }

    // გაშვება პატარა დაგვიანებით, რომ ბიბლიოთეკა დაჯდეს
    setTimeout(test, 1000);
</script>
</body>
</html>
