<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OLD MAFIA - პროფილი</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        body { background: #0b0000; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .profile-card { width: 340px; background: #070000; border: 2px solid red; border-radius: 20px; padding: 25px; text-align: center; box-shadow: 0 0 20px red; }
        .avatar { width: 100px; height: 100px; border-radius: 50%; border: 2px solid red; object-fit: cover; margin-bottom: 15px; background: #111; }
        .nick { font-size: 24px; font-weight: bold; color: red; display: block; }
        .role { font-size: 14px; color: gold; margin-bottom: 20px; display: block; }
        .status-text { background: #1a0000; padding: 10px; border-radius: 10px; border: 1px solid #333; margin-bottom: 20px; font-style: italic; min-height: 30px; color: #ccc; font-size: 13px; }
        .btn-box { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        button { padding: 10px; border-radius: 5px; border: 1px solid #500; background: #200; color: white; cursor: pointer; font-size: 10px; font-weight: bold; }
        button:hover { background: red; color: black; }
        .admin-panel { margin-top: 20px; padding-top: 15px; border-top: 1px dashed red; display: none; }
    </style>
</head>
<body>

<div class="profile-card">
    <img id="p-avatar" src="https://i.ibb.co/v3m6y6R/avatar.png" class="avatar">
    <span id="p-nick" class="nick">იტვირთება...</span>
    <span id="p-role" class="role">...</span>
    <div id="p-status" class="status-text">...</div>

    <div id="my-btns" class="btn-box" style="display:none;">
        <button onclick="editAvatar()">📷 ფოტოს შეცვლა</button>
        <button onclick="editStatus()">💬 სტატუსი</button>
    </div>

    <div id="admin-area" class="admin-panel">
        <p style="color:red; font-size:11px; margin-bottom: 10px;">ადმინისტრირება</p>
        <div class="btn-box">
            <button onclick="updateRole('Owner')">👑 დამფუძნებელი</button>
            <button onclick="updateRole('Admin')">🛡️ ადმინი</button>
            <button onclick="updateRole('Member')">✨ როლის ჩახსნა</button>
            <button onclick="updateRole('Ban')">🚫 დაბლოკვა</button>
        </div>
    </div>

    <button onclick="window.location.href='chat.html'" style="margin-top:20px; background:none; border:none; color:gray; text-decoration:underline; cursor:pointer;">⬅ უკან დაბრუნება</button>
</div>

<script>
    const _s = supabase.createClient("https://ftfciebnywbondaiarnc.supabase.co", "sb_publishable_eQZDSu_Jy1gWmXJFF800Pw_TP2kBRLI");
    
    // ვიღებთ იუზერს ლინკიდან
    const params = new URLSearchParams(window.location.search);
    const target = params.get('user'); 
    const myNick = localStorage.getItem('nickname');

    async function loadProfile() {
        if(!target) {
            document.getElementById('p-nick').innerText = "იუზერი არ არის";
            return;
        }

        let { data: p, error } = await _s.from('profiles').select('*').eq('username', target).maybeSingle();
        
        if(p) {
            document.getElementById('p-nick').innerText = p.username;
            document.getElementById('p-role').innerText = p.role || "Member";
            document.getElementById('p-status').innerText = p.daily_status || "სტატუსი არ არის";
            if(p.avatar_url) document.getElementById('p-avatar').src = p.avatar_url;

            // თუ ჩემი პროფილია, ვაჩვენოთ რედაქტირება
            if(myNick && myNick.toLowerCase() === target.toLowerCase()) {
                document.getElementById('my-btns').style.display = 'grid';
            }

            // თუ მე ვარ ადმინი, ვაჩვენოთ ადმინ პანელი სხვის პროფილზე
            if(myNick) {
                let { data: me } = await _s.from('profiles').select('role').eq('username', myNick).maybeSingle();
                if(me && (me.role === 'Admin' || me.role === 'Owner')) {
                    if(myNick.toLowerCase() !== target.toLowerCase()) {
                        document.getElementById('admin-area').style.display = 'block';
                    }
                }
            }
        } else {
            document.getElementById('p-nick').innerText = "ვერ მოიძებნა";
        }
    }

    async function updateRole(r) {
        if(confirm("ნამდვილად გსურთ?")) {
            const { error } = await _s.from('profiles').update({ role: r }).eq('username', target);
            if(error) alert("ბაზამ უარი თქვა!"); else location.reload();
        }
    }

    async function editAvatar() {
        const link = prompt("სურათის ლინკი:");
        if(link) {
            await _s.from('profiles').update({ avatar_url: link }).eq('username', myNick);
            location.reload();
        }
    }

    async function editStatus() {
        const st = prompt("ახალი სტატუსი:");
        if(st) {
            await _s.from('profiles').update({ daily_status: st }).eq('username', myNick);
            location.reload();
        }
    }

    window.onload = loadProfile;
</script>

</body>
</html>
