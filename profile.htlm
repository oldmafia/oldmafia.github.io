<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body style="background:white; color:black; padding:20px;">
    <h1 id="status">ვამოწმებ კავშირს...</h1>
    <div id="out"></div>

    <script>
        async function check() {
            const out = document.getElementById('out');
            const status = document.getElementById('status');

            try {
                const _s = supabase.createClient("https://ftfciebnywbondaiarnc.supabase.co", "sb_publishable_eQZDSu_Jy1gWmXJFF800Pw_TP2kBRLI");
                
                // ვცდილობთ ნებისმიერი რამის წაკითხვას profiles ცხრილიდან
                let { data, error } = await _s.from('profiles').select('username').limit(1);

                if (error) {
                    status.innerText = "❌ ბაზამ დააბრუნა შეცდომა:";
                    out.innerText = JSON.stringify(error, null, 2);
                } else {
                    status.innerText = "✅ კავშირი არის!";
                    out.innerText = "ბაზიდან მონაცემები მოვიდა. ე.ი. კოდი მუშაობს და პრობლემა ქეშირებაშია.";
                }
            } catch (e) {
                status.innerText = "💥 კოდი საერთოდ ვერ გაეშვა:";
                out.innerText = e.message;
            }
        }
        check();
    </script>
</body>
</html>
